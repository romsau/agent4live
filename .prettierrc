{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "arrowParens": "always",
  "endOfLine": "lf",
  "overrides": [
    {
      "files": ["app/lom_router.js", "app/lom_router/**/*.js"],
      "options": {
        "trailingComma": "es5"
      }
    }
  ]
}
